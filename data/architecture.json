{
  "_doc": "Carto d'architecture CURÉE (style Ontologie/Growth) — le « jumeau numérique » de karto. Layout figé (softcode), CONTENU data-driven : chaque boîte porte un `match` qui pointe vers ses vrais nœuds du graphe (DATA.graph) → compte + liste en tooltip au survol. Coordonnées en espace virtuel 1040x560 (le renderer met à l'échelle). tone = clé de couleur (core/host/account/db/secret/project/connector/domain/auto/human/machine/semantic).",
  "canvas": { "w": 1040, "h": 560 },
  "boxes": [
    { "id": "twin",     "label": "Jumeau numérique du SI",        "sub": "karto",                    "x": 400, "y": 16,  "w": 240, "h": 48, "tone": "core",     "match": { "all": true } },
    { "id": "semantic", "label": "Sémantique",                    "sub": "graphe entités · relations","x": 300, "y": 96,  "w": 190, "h": 42, "tone": "semantic", "match": { "all": true } },
    { "id": "kinetic",  "label": "Cinétique — actions",           "sub": "MCP · scénarios · OD",     "x": 550, "y": 96,  "w": 190, "h": 42, "tone": "semantic", "match": { "note": "Outils d'action : MCP karto (écriture), scénarios de résilience, écritures softcode." } },

    { "id": "base",     "label": "Base unifiée",                  "sub": "karto.db (graphe interrogeable)", "x": 400, "y": 176, "w": 240, "h": 52, "tone": "core", "match": { "all": true } },

    { "id": "hosts",    "label": "Hébergements",                  "x": 40,  "y": 150, "w": 170, "h": 40, "tone": "host",    "match": { "cat": "host" } },
